{
  // Cloudflare Workers (static assets) config for the portfolio.
  // With this file present, `npx wrangler deploy` uploads ./out as static
  // assets and SKIPS the Next.js OpenNext auto-conversion (which fails on
  // Next 14). The "name" must match your existing Worker project.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolioharish1333",
  "compatibility_date": "2026-06-27",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  }
}
