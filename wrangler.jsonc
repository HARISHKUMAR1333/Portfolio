{
  // Cloudflare Workers (static assets) config for the portfolio.
  // `npx wrangler deploy` uploads everything in ./out as static assets —
  // no Worker script needed for a fully static Next.js export.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "harishkumar-portfolio",
  "compatibility_date": "2026-06-27",
  "assets": {
    "directory": "./out",
    // Serve the styled 404 page for unknown paths.
    "not_found_handling": "404-page"
  }
}
